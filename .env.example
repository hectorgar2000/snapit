# ── Variables de entorno — SnapIT ─────────────────────────────────────────────
# Copia este archivo a .env para desarrollo local.
# En Railway/Render estas variables se configuran en el panel de Variables.

# OBLIGATORIO en producción: clave secreta para firmar los JWT.
# Genera una segura con: python -c "import secrets; print(secrets.token_hex(32))"
SNAPIT_SECRET=cambia-esto-por-una-clave-segura-min-32-chars

# Base de datos.
# - Local (por defecto): SQLite en snapit/snapit.db — no hace falta configurar nada.
# - Producción con Railway PostgreSQL addon:
#   DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_bd
# DATABASE_URL=postgresql://...

# Puerto (Railway lo inyecta automáticamente, no tocar).
# PORT=8000
